{
  "name": "@cisco-open/mcptoolkit-contract",
  "version": "1.0.0-rc2",
  "description": "CLI toolkit for MCP server contract management: dumps capabilities, generates changelogs and renders documentation",
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "mcpcontract": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "npm run build && node build/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:generate": "node tests/generators/catalog-test-generator.ts",
    "test:manual": "tests/run-manual-tests.sh",
    "test:links": "tests/check-doc-links.sh",
    "prerelease": "npm run test:links && npm run build && npm test",
    "clean": "rm -rf build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "contract",
    "manifest",
    "validation",
    "documentation"
  ],
  "author": "Stève Sfartz",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cisco-open/mcptoolkit-contract.git"
  },
  "bugs": {
    "url": "https://github.com/cisco-open/mcptoolkit-contract/issues"
  },
  "homepage": "https://github.com/cisco-open/mcptoolkit-contract#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^15.0.0",
    "handlebars": "^4.7.9",
    "markdown-it": "^14.2.0",
    "marked": "^18.0.5",
    "omelette": "^0.4.17",
    "openid-client": "^6.8.4",
    "semver": "^7.8.5",
    "snarkdown": "^2.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/omelette": "^0.4.5",
    "@types/semver": "^7.7.1",
    "jest": "^30.4.2",
    "typescript": "^6.0.3"
  },
  "files": [
    "build/",
    "schemas/",
    "templates/",
    "rules/",
    "LICENSE",
    "README.md"
  ],
  "overrides": {
    "js-yaml": "^4.2.0"
  }
}
