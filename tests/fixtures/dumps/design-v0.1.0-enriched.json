{
  "$schema": "https://developer.cisco.com/mcp_contract_dump/schema/0.3.4",
  "version": "0.3.4",
  "serverInfo": {
    "name": "design",
    "version": "0.1.0",
    "protocolVersion": "2025-06-18",
    "capabilities": {
      "tools": {}
    }
  },
  "tools": [
    {
      "name": "create_wireframe",
      "description": "Create a wireframe for a UI component",
      "tags": ["design", "wireframe"],
      "deprecated": false,
      "inputSchema": {
        "type": "object",
        "properties": {
          "component": {
            "type": "string",
            "description": "Name of the component",
            "examples": ["button", "modal", "navbar"]
          },
          "width": {
            "type": "integer",
            "description": "Width in pixels",
            "minimum": 100,
            "maximum": 1920
          }
        },
        "required": ["component"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to the generated wireframe"
          },
          "dimensions": {
            "type": "object",
            "properties": {
              "width": { "type": "integer" },
              "height": { "type": "integer" }
            }
          }
        }
      },
      "responseExamples": [
        {
          "name": "Button wireframe",
          "description": "Example of a simple button wireframe",
          "data": {
            "url": "https://example.com/wireframes/button-123.svg",
            "dimensions": {
              "width": 200,
              "height": 50
            }
          }
        },
        {
          "name": "Modal wireframe",
          "description": "Example of a modal dialog wireframe",
          "data": {
            "url": "https://example.com/wireframes/modal-456.svg",
            "dimensions": {
              "width": 600,
              "height": 400
            }
          }
        }
      ]
    }
  ],
  "prompts": [],
  "resources": [
    {
      "name": "design-system",
      "uri": "design://system/tokens",
      "description": "Design system tokens and guidelines",
      "tags": ["design-system", "tokens"],
      "deprecated": false,
      "contentExamples": [
        {
          "name": "Color tokens",
          "description": "Example of color token structure",
          "data": {
            "colors": {
              "primary": "#0066CC",
              "secondary": "#6C757D",
              "success": "#28A745"
            }
          }
        }
      ]
    }
  ],
  "resourceTemplates": [],
