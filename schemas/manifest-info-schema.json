{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://developer.cisco.com/mcpcontract/schema/manifest-info/1.0.0",
  "title": "MCP Manifest Complementary Info",
  "description": "Metadata required to generate a server.json manifest from a capability dump",
  "type": "object",
  "required": ["reverseDnsName", "description"],
  "properties": {
    "reverseDnsName": {
      "type": "string",
      "description": "Server name in reverse-DNS format",
      "pattern": "^[a-zA-Z0-9.-]+/[a-zA-Z0-9._-]+$",
      "examples": ["io.cisco.example/openapi-analyzer"]
    },
    "title": {
      "type": "string",
      "description": "Optional human-readable title",
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "Server description (max 100 chars)",
      "maxLength": 100,
      "minLength": 1
    },
    "version": {
      "type": "string",
      "description": "Server version (should match dump). If omitted, uses version from dump."
    },
    "repository": {
      "type": "object",
      "required": ["url", "source"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Repository URL"
        },
        "source": {
          "type": "string",
          "description": "Source forge",
          "examples": ["github", "gitlab"]
        },
        "id": {
          "type": "string",
          "description": "Repository ID from hosting service"
        },
        "subfolder": {
          "type": "string",
          "description": "Path within monorepo"
        }
      }
    },
    "websiteUrl": {
      "type": "string",
      "format": "uri",
      "description": "Project website or documentation"
    },
    "icons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["src"],
        "properties": {
          "src": {
            "type": "string",
            "format": "uri",
            "description": "HTTPS URL to icon"
          },
          "sizes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(\\d+x\\d+|any)$"
            }
          },
          "mimeType": {
            "type": "string",
            "enum": ["image/png", "image/jpeg", "image/jpg", "image/svg+xml", "image/webp"]
          },
          "theme": {
            "type": "string",
            "enum": ["light", "dark"]
          }
        }
      }
    },
    "packages": {
      "type": "array",
      "description": "Package distribution methods",
      "items": {
        "type": "object",
        "required": ["registryType", "identifier"],
        "properties": {
          "registryType": {
            "type": "string",
            "enum": ["npm", "pypi", "oci", "nuget", "mcpb"],
            "description": "Package registry type"
          },
          "registryBaseUrl": {
            "type": "string",
            "format": "uri",
            "description": "Base URL of package registry"
          },
          "identifier": {
            "type": "string",
            "description": "Package name or identifier"
          },
          "version": {
            "type": "string",
            "description": "Package version (if different from server version)"
          },
          "runtimeHint": {
            "type": "string",
            "enum": ["npx", "uvx", "docker", "dnx"],
            "description": "Runtime execution hint"
          },
          "transport": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["stdio", "streamable-http", "http", "sse"]
              },
              "url": {
                "type": "string",
                "description": "URL template (for HTTP transports)"
              }
            }
          },
          "environmentVariables": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Environment variable name"
                },
                "description": {
                  "type": "string",
                  "description": "Variable description"
                },
                "isRequired": {
                  "type": "boolean",
                  "default": false
                },
                "isSecret": {
                  "type": "boolean",
                  "default": false
                },
                "default": {
                  "type": "string",
                  "description": "Default value"
                },
                "choices": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              }
            }
          },
          "packageArguments": {
            "type": "array",
            "description": "CLI arguments to pass to package",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "required": ["type", "value"],
                  "properties": {
                    "type": {"const": "positional"},
                    "value": {"type": "string"},
                    "description": {"type": "string"}
                  }
                },
                {
                  "type": "object",
                  "required": ["type", "name"],
                  "properties": {
                    "type": {"const": "named"},
                    "name": {"type": "string"},
                    "value": {"type": "string"},
                    "description": {"type": "string"}
                  }
                }
              ]
            }
          },
          "runtimeArguments": {
            "type": "array",
            "description": "Arguments for runtime (e.g., docker run args)",
            "items": {
              "type": "object"
            }
          }
        }
      }
    },
    "remotes": {
      "type": "array",
      "description": "Remote/hosted server endpoints",
      "items": {
        "type": "object",
        "required": ["type", "url"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["streamable-http", "http", "sse"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "headers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {"type": "string"},
                "description": {"type": "string"},
                "isRequired": {"type": "boolean"},
                "isSecret": {"type": "boolean"},
                "default": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
