<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>API Inventory MCP Server v2.9.0</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: #111827;
      background: #f9fafb;
      padding: 2rem 1rem;
    }
    .container { max-width: 960px; margin: 0 auto; }
    a { color: #2563eb; text-decoration: none; }
    a:hover { text-decoration: underline; }
    code {
      font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', Consolas, monospace;
      font-size: 0.875em;
      background: #f3f4f6;
      padding: 0.125em 0.375em;
      border-radius: 0.25rem;
    }
    pre {
      background: #1f2937;
      color: #e5e7eb;
      padding: 1rem;
      border-radius: 0.5rem;
      overflow-x: auto;
      font-size: 0.8125rem;
      line-height: 1.5;
    }
    pre code { background: none; padding: 0; color: inherit; }

    /* Cards */
    .card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      padding: 1.5rem;
      margin-bottom: 1rem;
      box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }

    /* Info card */
    .info-card .title-row {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .info-card h1 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #111827;
    }
    .info-card .description { margin-top: 0.75rem; color: #374151; }
    .info-card .meta { margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; font-size: 0.875rem; color: #6b7280; }
    .info-card .meta-item { display: flex; align-items: center; gap: 0.25rem; }

    /* Badges */
    .badge {
      display: inline-block;
      font-size: 0.6875rem;
      font-weight: 600;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
      text-transform: uppercase;
      letter-spacing: 0.025em;
      vertical-align: middle;
    }
    .badge.version { background: #dbeafe; color: #1e40af; }
    .badge.protocol { background: #e0e7ff; color: #3730a3; }
    .badge.transport { background: #fef3c7; color: #92400e; }
    .badge.tool { background: #d1fae5; color: #065f46; }
    .badge.prompt { background: #ede9fe; color: #5b21b6; }
    .badge.resource { background: #fce7f3; color: #9d174d; }
    .badge.template { background: #ffedd5; color: #9a3412; }
    .badge.deprecated { background: #fef2f2; color: #991b1b; font-style: italic; }
    .badge.required { background: #fee2e2; color: #991b1b; font-size: 0.625rem; }
    .badge.tag { background: #f3f4f6; color: #374151; font-size: 0.625rem; font-weight: 500; text-transform: none; }
    .badge.cors-ready { background: #d1fae5; color: #065f46; }
    .badge.cors-fail { background: #fef2f2; color: #991b1b; }
    .badge.security { background: #fef9c3; color: #854d0e; }
    .badge.hint { background: #f3f4f6; color: #6b7280; font-weight: 500; text-transform: none; }

    /* Section headers */
    h2 {
      font-size: 1.125rem;
      font-weight: 600;
      color: #111827;
      display: inline;
    }
    .section-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; }
    .count { font-size: 0.8125rem; color: #9ca3af; font-weight: 400; }
    .section-icon { font-size: 1.125rem; }

    /* Details / collapsible */
    details { border: none; }
    details > summary {
      cursor: pointer;
      user-select: none;
      list-style: none;
      padding: 0;
      display: flex;
      align-items: center;
    }
    details > summary::-webkit-details-marker { display: none; }
    details > summary::before {
      content: '▶';
      display: inline-block;
      font-size: 0.625rem;
      margin-right: 0.5rem;
      flex-shrink: 0;
      transition: transform 0.15s ease;
      color: #9ca3af;
    }
    details[open] > summary::before { transform: rotate(90deg); }

    /* Item cards (tools, prompts, etc.) */
    .item-detail {
      border: 1px solid #f3f4f6;
      border-radius: 0.5rem;
      margin-bottom: 0.5rem;
      overflow: hidden;
    }
    .item-detail > summary {
      padding: 0.625rem 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      background: #fafafa;
    }
    .item-detail > summary:hover { background: #f3f4f6; }
    .item-detail > summary .name { font-weight: 600; font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace; font-size: 0.875rem; }
    .item-detail > summary .title-text { color: #6b7280; font-size: 0.875rem; }
    .item-body { padding: 0.75rem 1rem 1rem; border-top: 1px solid #f3f4f6; }
    .item-body .description { color: #374151; font-size: 0.875rem; margin-bottom: 0.75rem; }

    /* Annotations / hints row */
    .hints { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 0.75rem; }

    /* Tags row */
    .tags { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-bottom: 0.5rem; }

    /* Schema tables */
    .schema-section { margin-top: 0.5rem; }
    .schema-toggle {
      font-size: 0.8125rem;
      font-weight: 600;
      color: #6b7280;
      padding: 0.25rem 0;
    }
    .schema-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.8125rem;
      margin-top: 0.375rem;
    }
    .schema-table th {
      text-align: left;
      color: #9ca3af;
      font-weight: 500;
      padding: 0.375rem 0.5rem;
      border-bottom: 1px solid #e5e7eb;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .schema-table td {
      padding: 0.375rem 0.5rem;
      border-bottom: 1px solid #f3f4f6;
      vertical-align: top;
    }
    .schema-table td:first-child { font-weight: 500; }
    .type-pill {
      display: inline-block;
      font-size: 0.6875rem;
      padding: 0.0625rem 0.375rem;
      border-radius: 0.25rem;
      background: #eff6ff;
      color: #1d4ed8;
      font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace;
    }
    .schema-json { margin-top: 0.5rem; }

    /* Transport items */
    .transport-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid #f9fafb;
      font-size: 0.875rem;
    }
    .transport-item:last-child { border-bottom: none; }
    .transport-url { color: #6b7280; word-break: break-all; }

    /* URI display */
    .uri { color: #6b7280; font-size: 0.8125rem; word-break: break-all; font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace; }

    /* Resource / prompt argument list */
    .arg-list { margin: 0; padding: 0; list-style: none; }
    .arg-list li {
      padding: 0.25rem 0;
      font-size: 0.8125rem;
      border-bottom: 1px solid #f9fafb;
    }
    .arg-list li:last-child { border-bottom: none; }
    .arg-name { font-weight: 600; font-family: 'SF Mono', 'Cascadia Code', Consolas, monospace; }

    /* Footer */
    .footer {
      text-align: center;
      color: #9ca3af;
      font-size: 0.75rem;
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid #e5e7eb;
    }

    /* Responsive */
    @media (max-width: 640px) {
      body { padding: 1rem 0.5rem; }
      .card { padding: 1rem; }
      .info-card h1 { font-size: 1.25rem; }
    }
  </style>
</head>
<body>
  <div class="container">

    <!-- Info Card -->
    <div class="card info-card">
      <div class="title-row">
        <h1>API Inventory MCP Server</h1>
        <span class="badge version">v2.9.0</span>
        <span class="badge protocol">MCP 2025-06-18</span>
      </div>
      
      <div class="meta">
        <span class="meta-item"><strong>Name:</strong>&nbsp;mcp-inventory</span>
        
        
        
        
      </div>
    </div>

    <!-- Transports -->
    <div class="card">
      <div class="section-header">
        <span class="section-icon">🔌</span>
        <h2>Transports</h2>
        <span class="count">(1)</span>
      </div>
      <div class="transport-item">
        <span class="badge transport">streamable-http</span>
        <span class="transport-url">http://localhost:3000/mcp</span>
        
      </div>
    </div>

    <!-- Security -->

    <!-- Tools -->
    <div class="card">
      <details open>
        <summary>
          <div class="section-header">
            <span class="section-icon">🔧</span>
            <h2>Tools</h2>
            <span class="count">(6)</span>
          </div>
        </summary>
        <details class="item-detail" open>
          <summary>
            <span class="badge tool">tool</span>
            <span class="name">search</span>
            
            
          </summary>
          <div class="item-body">
            <div class="tags">
              <span class="badge tag">query</span>
            </div>
            <div class="description">Search and filter Cisco's API/SDK inventory. Supports filtering by kind (API/SDK/GROUP), organization (CN, SBG, CTG, CX, etc.), and name with partial matching. Returns paginated results with optional field selection.<br />Common Usage Patterns:<ol><li>Search by name: {"name": "Nexus Dashboard", "partial": true}</li><li>Filter by organization: {"organization": "SBG"}</li><li>Find APIs only: {"kind": "API"}</li><li>Combine filters: {"kind": "API", "organization": "SBG", "name": "defense"}</li><li>Get specific details: {"name": "API name", "details": "contacts"}</li><li>Pagination: {"pageSize": 20, "cursor": "previous<em>cursor"}</em></li></ol><br />Parameter Details:<ul><li>name: Search card names (case-insensitive, partial matching by default)</li><li>kind: API, SDK, or GROUP</li><li>organization: CN, SBG, CTG, CX, Operations, CSDI, Splunk, Sales</li><li>partial: true (default) for substring match, false for exact match</li><li>details: contacts, releases, api<em>quality, api</em>insights, info</li><li>pageSize: 1-100 (default: 10)</li><li>cursor: from previous response for next page</li></ul><br />Related Prompts: Use "search" prompt for guided API discovery<br />Error Handling:<ul><li>Returns -32602 (InvalidParams) for invalid parameters with detailed validation errors</li><li>Returns -32603 (InternalError) for server-side issues</li></ul></div>
            <div class="schema-section">
              <details open>
                <summary class="schema-toggle">Input Schema</summary>
                <table class="schema-table">
                  <thead><tr><th>Property</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
                  <tbody>
                    <tr>
                      <td><code>kind</code></td>
                      <td>
                        <span class="type-pill">string</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Filter by card type: API (REST, gRPC, GraphQL, etc.), SDK (JavaScript, Python, Swift, etc.), MCP (Model Context Protocol servers), or GROUP (logical collections). **Required when using organization filter**.
                        
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>audience</code></td>
                      <td>
                        <span class="type-pill">string</span>
                         &quot;EXTERNAL&quot; | &quot;INTERNAL&quot;
                      </td>
                      <td></td>
                      <td>
                        Filter by target audience: EXTERNAL (public customer/partner facing) or INTERNAL (Cisco-internal). Default: EXTERNAL. GROUP cards are automatically included if they contain any matching API/SDK/MCP cards.
                         <em>Default: EXTERNAL</em>
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>organization</code></td>
                      <td>
                        <span class="type-pill">string</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Filter by organization code (CN, SBG, CTG, CX, Operations, CSDI, Splunk, Sales). **Requires kind to be &quot;API&quot;, &quot;SDK&quot;, or &quot;MCP&quot;**. GROUP cards do not have organization. Supports partial matching when partial&#x3D;true
                        
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>name</code></td>
                      <td>
                        <span class="type-pill">string</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Filter by card name or alternate names. Case-insensitive with partial matching by default. Example: &quot;defense&quot; matches &quot;AI Defense API&quot;
                        
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>partial</code></td>
                      <td>
                        <span class="type-pill">boolean</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Enable partial/substring matching for name and organization (default: true). Set to false for exact matches only
                         <em>Default: true</em>
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>details</code></td>
                      <td>
                        <span class="type-pill">string</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Return only specific section: contacts (team info), releases (versions/phase and reviews; note: deprecated &#x60;status&#x60; field mirrors &#x60;phase&#x60; for backward compatibility), api_quality (metrics), api_insights (org mapping), or info (basic metadata)
                        
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>cursor</code></td>
                      <td>
                        <span class="type-pill">string</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Pagination cursor from previous response. Use the &quot;cursor&quot; value returned in results to fetch next page
                        
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>pageSize</code></td>
                      <td>
                        <span class="type-pill">number</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Number of results per page. Default is from config (typically 10), maximum 100. Returns hasMore&#x3D;true if more results available
                        
                         <em>Range: 1-100</em>
                        
                        
                        
                      </td>
                    </tr>
                  </tbody>
                </table>
              </details>
            </div>
          </div>
        </details>
        <details class="item-detail">
          <summary>
            <span class="badge tool">tool</span>
            <span class="name">refresh-cache</span>
            
            
          </summary>
          <div class="item-body">
            <div class="tags">
              <span class="badge tag">operations</span>
            </div>
            <div class="description">Manually trigger an inventory refresh from the remote URL. The server automatically refreshes every 15 minutes, but this tool allows on-demand updates. Returns the new version number and update status. Note: Updates only occur if the remote version is different from the cached version.<br />Common Usage Pattern:<ol><li>Check for updates: {} (no parameters needed)</li></ol><br />Parameter Details:<ul><li>No parameters required</li></ul><br />Returns:<ul><li>success: true/false</li><li>message: Status description</li><li>version: Current inventory version</li></ul><br />Error Handling:<ul><li>Returns -32001 (ServiceUnavailable) if remote inventory URL is unreachable (retryable)</li><li>Returns -32603 (InternalError) for other server-side issues</li></ul></div>
            <div class="schema-section">
              <details open>
                <summary class="schema-toggle">Input Schema</summary>
                <table class="schema-table">
                  <thead><tr><th>Property</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
                  <tbody>
                  </tbody>
                </table>
              </details>
            </div>
          </div>
        </details>
        <details class="item-detail">
          <summary>
            <span class="badge tool">tool</span>
            <span class="name">stats</span>
            
            
          </summary>
          <div class="item-body">
            <div class="tags">
              <span class="badge tag">operations</span>
            </div>
            <div class="description">Generate statistical analysis of the inventory with optional grouping. Get aggregate counts and distributions grouped by: organization (CN, SBG, CTG, etc.), status (ACTIVE, EOL, ONBOARDING), kind (API, SDK, GROUP), deployment (Cloud, On-prem), or lifecycle (Product-led, API-led, etc.). Without grouping, returns overall counts.<br />Common Usage Patterns:<ol><li>Overall statistics: {} (no parameters)</li><li>By organization: {"groupBy": "organization"}</li><li>By status: {"groupBy": "status"}</li><li>By kind: {"groupBy": "kind"}</li><li>By deployment: {"groupBy": "deployment"}</li><li>By lifecycle: {"groupBy": "lifecycle"}</li></ol><br />Parameter Details:<ul><li>groupBy (optional): organization, status, kind, deployment, lifecycle</li><li>Omit groupBy for overall totals</li></ul><br />Related Prompts: Use "organization-report" prompt for detailed org analysis<br />Error Handling:<ul><li>Returns -32602 (InvalidParams) for invalid groupBy values</li><li>Returns -32603 (InternalError) for server-side issues</li></ul></div>
            <div class="schema-section">
              <details open>
                <summary class="schema-toggle">Input Schema</summary>
                <table class="schema-table">
                  <thead><tr><th>Property</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
                  <tbody>
                    <tr>
                      <td><code>groupBy</code></td>
                      <td>
                        <span class="type-pill">string</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Group statistics by: organization (CN, SBG, CTG, etc.), status (ACTIVE, EOL, ONBOARDING), kind (API, SDK, MCP), deployment (Cloud, On-prem), lifecycle (Product-led, API-led, etc.), or audience (EXTERNAL, INTERNAL). Omit to get default grouping by kind. Returns total count and breakdown with counts per group
                        
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>audience</code></td>
                      <td>
                        <span class="type-pill">string</span>
                         &quot;EXTERNAL&quot; | &quot;INTERNAL&quot;
                      </td>
                      <td></td>
                      <td>
                        Filter statistics by target audience: EXTERNAL (public customer/partner facing) or INTERNAL (Cisco-internal). Default: EXTERNAL. GROUP cards are always excluded from statistics as they do not have an audience field.
                         <em>Default: EXTERNAL</em>
                        
                        
                        
                        
                      </td>
                    </tr>
                  </tbody>
                </table>
              </details>
            </div>
          </div>
        </details>
        <details class="item-detail">
          <summary>
            <span class="badge tool">tool</span>
            <span class="name">list-organizations</span>
            
            
          </summary>
          <div class="item-body">
            <div class="tags">
              <span class="badge tag">operations</span>
            </div>
            <div class="description">List all Cisco organizations present in the inventory. Returns an array of organization codes (e.g., CN, SBG, CTG, CX, Operations, CSDI, Splunk, Sales). Useful for agent discoverability and UI dropdowns.</div>
            <div class="schema-section">
              <details open>
                <summary class="schema-toggle">Input Schema</summary>
                <table class="schema-table">
                  <thead><tr><th>Property</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
                  <tbody>
                  </tbody>
                </table>
              </details>
            </div>
          </div>
        </details>
        <details class="item-detail">
          <summary>
            <span class="badge tool">tool</span>
            <span class="name">schema-version</span>
            
            
          </summary>
          <div class="item-body">
            <div class="tags">
              <span class="badge tag">operations</span>
            </div>
            <div class="description">Get information about inventory schema version compatibility. Returns the supported schema version, current inventory version, and compatibility status. Use this to check if the loaded inventory is compatible with the MCP server.</div>
            <div class="schema-section">
              <details open>
                <summary class="schema-toggle">Input Schema</summary>
                <table class="schema-table">
                  <thead><tr><th>Property</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
                  <tbody>
                  </tbody>
                </table>
              </details>
            </div>
          </div>
        </details>
        <details class="item-detail">
          <summary>
            <span class="badge tool">tool</span>
            <span class="name">get-card</span>
            
            
          </summary>
          <div class="item-body">
            <div class="tags">
              <span class="badge tag">query</span>
            </div>
            <div class="description">Retrieve detailed information for a specific card by its ID. This tool provides the same functionality as the card:/// resource but is compatible with MCP clients that do not support resource fetching (e.g., GitHub Copilot). Returns complete card metadata including name, description, contacts, releases, and quality metrics.<br />Common Usage Patterns:<ol><li>Get full card details: {"id": "cisco-secure-network-analytics-api"}</li><li>Get specific section: {"id": "card-id", "details": "contacts"}</li><li>Check releases: {"id": "card-id", "details": "releases"}</li></ol><br />Parameter Details:<ul><li>id: Card identifier (use search tool to find IDs)</li><li>details (optional): contacts, releases, api<em>quality, api</em>insights, info</li></ul><br />Note: For MCP clients with resource support, use card:///{id} resource instead.<br />Error Handling:<ul><li>Returns -32602 (InvalidParams) for invalid parameters</li><li>Returns -32603 (InternalError) if card not found or server error</li></ul></div>
            <div class="schema-section">
              <details open>
                <summary class="schema-toggle">Input Schema</summary>
                <table class="schema-table">
                  <thead><tr><th>Property</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
                  <tbody>
                    <tr>
                      <td><code>id</code></td>
                      <td>
                        <span class="type-pill">string</span>
                        
                      </td>
                      <td><span class="badge required">required</span></td>
                      <td>
                        The unique identifier of the card to retrieve (e.g., &quot;cisco-secure-network-analytics-api&quot;)
                        
                        
                        
                        
                        
                      </td>
                    </tr>
                    <tr>
                      <td><code>details</code></td>
                      <td>
                        <span class="type-pill">string</span>
                        
                      </td>
                      <td></td>
                      <td>
                        Return only specific section: contacts (team info), releases (versions/phase and reviews; note: deprecated &#x60;status&#x60; field mirrors &#x60;phase&#x60; for backward compatibility), api_quality (metrics), api_insights (org mapping), or info (basic metadata)
                        
                        
                        
                        
                        
                      </td>
                    </tr>
                  </tbody>
                </table>
              </details>
            </div>
          </div>
        </details>
      </details>
    </div>

    <!-- Prompts -->
    <div class="card">
      <details open>
        <summary>
          <div class="section-header">
            <span class="section-icon">💬</span>
            <h2>Prompts</h2>
            <span class="count">(5)</span>
          </div>
        </summary>
        <details class="item-detail" open>
          <summary>
            <span class="badge prompt">prompt</span>
            <span class="name">search</span>
            
            
          </summary>
          <div class="item-body">
            <div class="tags">
              <span class="badge tag">query</span>
            </div>
            <div class="description">Guided API discovery with intelligent filtering. Find APIs by organization (CN, SBG, CTG, CX, etc.), style (REST, gRPC, GraphQL), deployment type (Cloud, On-prem), or status (ACTIVE, EOL, ONBOARDING). Returns a curated summary with names, descriptions, and key characteristics. Use this for exploratory API searches when you need context and recommendations.</div>
          </div>
        </details>
        <details class="item-detail">
          <summary>
            <span class="badge prompt">prompt</span>
            <span class="name">api-quality-metrics</span>
            
            
          </summary>
          <div class="item-body">
            <div class="tags">
